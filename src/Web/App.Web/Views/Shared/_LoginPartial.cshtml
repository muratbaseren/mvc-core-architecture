@using App.Infrastructure.Identity
@using Microsoft.AspNetCore.Identity
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

<div class="flex items-center gap-3 text-sm">
    @if (SignInManager.IsSignedIn(User))
    {
        <span class="text-gray-600 hidden sm:inline">Merhaba, <strong>@UserManager.GetUserName(User)</strong></span>
        <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
            <button type="submit"
                    class="rounded-lg bg-gray-100 hover:bg-gray-200 text-gray-700 px-3 py-1.5">
                Çıkış
            </button>
        </form>
    }
    else
    {
        <a asp-controller="Account" asp-action="Login"
           class="text-gray-600 hover:text-indigo-600">Giriş</a>
        <a asp-controller="Account" asp-action="Register"
           class="rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white px-3 py-1.5">
            Kayıt Ol
        </a>
    }
</div>
