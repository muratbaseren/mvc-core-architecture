@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<div class="max-w-lg mx-auto text-center py-16">
    <h1 class="text-5xl font-bold text-red-600">Hata</h1>
    <p class="mt-4 text-gray-600">İsteğiniz işlenirken beklenmeyen bir hata oluştu.</p>

    @if (Model.ShowRequestId)
    {
        <p class="mt-4 text-sm text-gray-500">
            İstek No: <code class="bg-gray-100 px-1 rounded">@Model.RequestId</code>
        </p>
    }

    <a asp-controller="Home" asp-action="Index"
       class="mt-8 inline-block rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5">
        Ana Sayfaya Dön
    </a>
</div>
