@using App.SharedKernel.Modules
<!DOCTYPE html>
<html lang="tr" class="h-full bg-gray-50">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Modüler Mimari</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="h-full flex flex-col min-h-screen text-gray-800">
    <header class="bg-white border-b border-gray-200 shadow-sm">
        <nav class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
            <div class="flex items-center gap-6">
                <a asp-controller="Home" asp-action="Index"
                   class="text-lg font-bold text-indigo-600 hover:text-indigo-700">
                    ⬡ Modüler Mimari
                </a>
                <div class="hidden sm:flex items-center gap-4 text-sm">
                    <a asp-controller="Home" asp-action="Index"
                       class="text-gray-600 hover:text-indigo-600">Ana Sayfa</a>
                    @foreach (var item in ModuleRegistry.Modules
                        .SelectMany(m => m.MenuItems)
                        .OrderBy(i => i.Order))
                    {
                        <a href="@item.Url" class="text-gray-600 hover:text-indigo-600">@item.Title</a>
                    }
                    <a href="/graphql" class="text-gray-600 hover:text-indigo-600">GraphQL</a>
                </div>
            </div>
            <partial name="_LoginPartial" />
        </nav>
    </header>

    <main class="flex-1 max-w-6xl w-full mx-auto px-4 py-8">
        @if (TempData["Success"] is string success)
        {
            <div class="mb-6 rounded-lg bg-green-50 border border-green-200 text-green-800 px-4 py-3 text-sm">
                @success
            </div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="mb-6 rounded-lg bg-red-50 border border-red-200 text-red-800 px-4 py-3 text-sm">
                @error
            </div>
        }
        @RenderBody()
    </main>

    <footer class="border-t border-gray-200 bg-white">
        <div class="max-w-6xl mx-auto px-4 py-4 text-sm text-gray-500 flex items-center justify-between">
            <span>&copy; @DateTime.Now.Year - ASP.NET Core Modüler Clean Architecture</span>
            <span>Yüklü modül: @ModuleRegistry.Modules.Count</span>
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
