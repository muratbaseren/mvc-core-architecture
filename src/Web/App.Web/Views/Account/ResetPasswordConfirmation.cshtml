@{
    ViewData["Title"] = "Şifre Sıfırlandı";
}

<div class="max-w-md mx-auto text-center py-12">
    <div class="rounded-xl border border-gray-200 bg-white p-8 shadow-sm">
        <div class="text-4xl mb-4">✅</div>
        <h1 class="text-2xl font-bold text-gray-900">Şifreniz Sıfırlandı</h1>
        <p class="mt-3 text-gray-600">Artık yeni şifrenizle giriş yapabilirsiniz.</p>
        <a asp-action="Login"
           class="mt-6 inline-block rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5">
            Giriş Yap
        </a>
    </div>
</div>
