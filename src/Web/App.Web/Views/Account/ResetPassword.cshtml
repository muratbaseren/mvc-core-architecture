@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Şifre Sıfırlama";
}

<div class="max-w-md mx-auto">
    <div class="rounded-xl border border-gray-200 bg-white p-8 shadow-sm">
        <h1 class="text-2xl font-bold text-gray-900 mb-6">Yeni Şifre Belirle</h1>

        <form asp-action="ResetPassword" method="post" class="space-y-4">
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600"></div>
            <input asp-for="Email" type="hidden" />
            <input asp-for="Code" type="hidden" />

            <div>
                <label asp-for="Password" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="Password" autocomplete="new-password"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <span asp-validation-for="Password" class="text-sm text-red-600"></span>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="block text-sm font-medium text-gray-700 mb-1"></label>
                <input asp-for="ConfirmPassword" autocomplete="new-password"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <span asp-validation-for="ConfirmPassword" class="text-sm text-red-600"></span>
            </div>

            <button type="submit"
                    class="w-full rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white py-2.5 font-medium">
                Şifreyi Sıfırla
            </button>
        </form>
    </div>
</div>
