@model App.Modules.Products.Application.Commands.CreateProductCommand
@{
    ViewData["Title"] = "Yeni Ürün";
}

<div class="max-w-lg mx-auto">
    <div class="rounded-xl border border-gray-200 bg-white p-8 shadow-sm">
        <h1 class="text-2xl font-bold text-gray-900 mb-6">Yeni Ürün</h1>

        <form asp-action="Create" method="post" class="space-y-4">
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600"></div>

            <div>
                <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1">Ürün Adı</label>
                <input asp-for="Name"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <span asp-validation-for="Name" class="text-sm text-red-600"></span>
            </div>

            <div>
                <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1">Açıklama</label>
                <textarea asp-for="Description" rows="3"
                          class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500"></textarea>
                <span asp-validation-for="Description" class="text-sm text-red-600"></span>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="Price" class="block text-sm font-medium text-gray-700 mb-1">Fiyat (₺)</label>
                    <input asp-for="Price" type="number" step="0.01" min="0"
                           class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                    <span asp-validation-for="Price" class="text-sm text-red-600"></span>
                </div>
                <div>
                    <label asp-for="Stock" class="block text-sm font-medium text-gray-700 mb-1">Stok</label>
                    <input asp-for="Stock" type="number" min="0"
                           class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                    <span asp-validation-for="Stock" class="text-sm text-red-600"></span>
                </div>
            </div>

            <div class="flex gap-3 pt-2">
                <button type="submit"
                        class="flex-1 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white py-2.5 font-medium">
                    Kaydet
                </button>
                <a asp-action="Index"
                   class="flex-1 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 py-2.5 font-medium text-center">
                    İptal
                </a>
            </div>
        </form>
    </div>
</div>
