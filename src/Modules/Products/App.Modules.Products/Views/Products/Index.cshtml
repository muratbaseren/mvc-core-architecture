@model List<Product>
@{
    ViewData["Title"] = "Ürünler";
}

<div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Ürünler</h1>
    <a asp-action="Create"
       class="rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 text-sm font-medium">
        + Yeni Ürün
    </a>
</div>

@if (Model.Count == 0)
{
    <div class="rounded-xl border border-dashed border-gray-300 bg-white p-10 text-center text-gray-500">
        Henüz ürün yok. İlk ürününüzü ekleyin.
    </div>
}
else
{
    <div class="overflow-x-auto rounded-xl border border-gray-200 bg-white shadow-sm">
        <table class="min-w-full divide-y divide-gray-200 text-sm">
            <thead class="bg-gray-50 text-left text-gray-600">
                <tr>
                    <th class="px-4 py-3 font-medium">Ürün</th>
                    <th class="px-4 py-3 font-medium">Fiyat</th>
                    <th class="px-4 py-3 font-medium">Stok</th>
                    <th class="px-4 py-3 font-medium">Durum</th>
                    <th class="px-4 py-3 font-medium text-right">İşlemler</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var product in Model)
                {
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3">
                            <div class="font-medium text-gray-900">@product.Name</div>
                            @if (!string.IsNullOrEmpty(product.Description))
                            {
                                <div class="text-gray-500 truncate max-w-xs">@product.Description</div>
                            }
                        </td>
                        <td class="px-4 py-3 text-gray-900">@product.Price.ToString("C2", new System.Globalization.CultureInfo("tr-TR"))</td>
                        <td class="px-4 py-3">@product.Stock</td>
                        <td class="px-4 py-3">
                            @if (product.IsActive)
                            {
                                <span class="rounded-full bg-green-50 text-green-700 px-2 py-0.5 text-xs">Aktif</span>
                            }
                            else
                            {
                                <span class="rounded-full bg-gray-100 text-gray-600 px-2 py-0.5 text-xs">Pasif</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-right whitespace-nowrap">
                            <a asp-action="Edit" asp-route-id="@product.Id"
                               class="text-indigo-600 hover:underline mr-3">Düzenle</a>
                            <form asp-action="Delete" asp-route-id="@product.Id" method="post" class="inline"
                                  onsubmit="return confirm('Bu ürünü silmek istediğinize emin misiniz?');">
                                <button type="submit" class="text-red-600 hover:underline">Sil</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
